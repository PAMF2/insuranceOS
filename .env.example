# ===========================
# InsuranceOS — Configuração
# ===========================

# ── LLM Provider (v0.2+) ──────────────────────────────────
# Provedor padrão (gemini | anthropic | openai | ollama)
INSURANCEOS_LLM_PROVIDER=gemini

# Google Gemini
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Anthropic Claude (opcional)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-6

# OpenAI (opcional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Ollama local (opcional)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── WhatsApp (Meta Cloud API) ─────────────────────────────
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=insuranceos_verify

# ── Telegram (alertas internos) ───────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Google Sheets (CRM) ───────────────────────────────────
GOOGLE_SHEETS_ID=
GOOGLE_SHEETS_CREDENTIALS_FILE=credentials.json
# Ou JSON inline (para deploy em nuvem):
# GOOGLE_SHEETS_CREDENTIALS_JSON=

# ── ADK Server ────────────────────────────────────────────
ADK_API_BASE=http://localhost:8000
ADK_APP_NAME=insurance_agent
ADK_REQUEST_STYLE=camel

# ── Segurança ─────────────────────────────────────────────
WEBHOOK_TOKEN=mude-este-token-agora

# ── Servidor ──────────────────────────────────────────────
PORT=8080
HOST=0.0.0.0
DEBUG=false
LOG_LEVEL=INFO

# ── PicoClaw Monitor (v0.2) ───────────────────────────────
PICO_RENEWAL_INTERVAL_H=6
PICO_LEADS_INTERVAL_H=12
PICO_HEALTH_INTERVAL_S=60

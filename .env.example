# ===========================
# InsuranceOS — Configuração
# ===========================

# LLM Provider
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# OpenAI (opcional)
OPENAI_API_KEY=

# Anthropic (opcional)
ANTHROPIC_API_KEY=

# WhatsApp (Meta Cloud API)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=insuranceos_verify

# Telegram (alertas internos para corretores)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Google Sheets (CRM + Apólices)
GOOGLE_SHEETS_ID=
GOOGLE_SHEETS_CREDENTIALS_FILE=credentials.json
# Ou JSON inline (para deploy):
# GOOGLE_SHEETS_CREDENTIALS_JSON=

# ADK Server
ADK_API_BASE=http://localhost:8000
ADK_APP_NAME=insurance_agent
ADK_REQUEST_STYLE=camel

# Segurança
WEBHOOK_TOKEN=mude-este-token

# Servidor
PORT=8080
HOST=0.0.0.0

# Modo
DEBUG=false
LOG_LEVEL=INFO
